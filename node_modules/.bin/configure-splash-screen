#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -x "$basedir/node" ]; then
  "$basedir/node"  "$basedir/../@expo/config-plugins/node_modules/@expo/configure-splash-screen/build/index-cli.js" "$@"
  ret=$?
else 
  node  "$basedir/../@expo/config-plugins/node_modules/@expo/configure-splash-screen/build/index-cli.js" "$@"
  ret=$?
fi
exit $ret
